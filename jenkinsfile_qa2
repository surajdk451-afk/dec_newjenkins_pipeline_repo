pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                checkout([$class: 'GitSCM', 
                     branches: [[name: '*/main']],
                     extensions: [],
                     userRemoteConfigs: [[
                     credentialsId: 'surajdk',
                     url: 'https://github.com/surajdk/my-repo.git'
                     ]]])
            }
        }
        stage('Build') {
            steps {
                sh'''
                    #!/bin/bash
                    echo "Building the project..."
                    ls -lrt
                '''
            }
        }
        stage('Push to GitHub') {
            steps {
                sh'''
                    #!/bin/bash
                    git config user.email "jenkins@example.com"
                    git config user.name "Jenkins"
                    git add .
                    git commit -m "Pipeline run"
                    git push origin main
                '''
            }
        }
    }
}             